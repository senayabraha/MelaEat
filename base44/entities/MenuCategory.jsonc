{
  "name": "MenuCategory",
  "type": "object",
  "properties": {
    "restaurant_id": {
      "type": "string",
      "description": "Owning restaurant id"
    },
    "name": {
      "type": "string",
      "description": "Category name (e.g. Wots, Tibs, Drinks)"
    },
    "description": {
      "type": "string"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "restaurant_id",
    "name"
  ]
}